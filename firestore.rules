rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ───
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.isAdmin == false; // can never self-register as admin
      allow update: if request.auth != null && request.auth.uid == userId
        // Block any update that tries to change isAdmin, unless it's already true (admin editing own doc)
        && (request.resource.data.isAdmin == resource.data.isAdmin);
    }

    // ─── Listings ───
    match /listings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.sellerId == request.auth.uid;
    }

    // ─── Trades ───
    match /trades/{tradeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // ─── Gold Block Transactions ───
    match /gbTransactions/{txId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // ─── Debt Ledger ───
    match /debtLedger/{debtId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Admin ───
    match /admin/{document=**} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
